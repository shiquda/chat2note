# Chat2Note Environment Variables

# Development Environment Configuration
# Chrome 可执行文件路径 (可选)
# WXT_CHROME_BINARY=C:/Program Files/Google/Chrome/Application/chrome.exe

# Firefox 可执行文件路径 (可选)
# FIREFOX_BINARY=D:/Program Files/Zen Browser/zen.exe

# Firefox 配置文件路径 (可选)
# FIREFOX_PROFILE=C:/Users/YourUser/AppData/Roaming/zen/Profiles/your-profile

# Chrome 配置文件路径 (可选)
# CHROMIUM_PROFILE=.wxt/chrome-data
