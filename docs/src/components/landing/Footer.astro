---
const currentYear = new Date().getFullYear()
---

<footer class="bg-gray-900 text-gray-300">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <div class="flex items-center space-x-2 mb-4">
          <img src="/logo.svg" alt="Chat2Note Logo" class="h-8 w-8" />
          <span class="text-xl font-bold text-white">Chat2Note</span>
        </div>
        <p class="text-sm text-gray-400 leading-relaxed">
          Privacy-first browser extension for exporting AI chat conversations.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h3 class="text-white font-semibold mb-4">Product</h3>
        <ul class="space-y-2">
          <li>
            <a href="/#features" class="text-sm hover:text-primary-400 transition-colors">Features</a>
          </li>
          <li>
            <a href="/#platforms" class="text-sm hover:text-primary-400 transition-colors">Platforms</a>
          </li>
          <li>
            <a href="/docs" class="text-sm hover:text-primary-400 transition-colors">Documentation</a>
          </li>
          <li>
            <a href="https://github.com/shiquda/chat2note/releases" class="text-sm hover:text-primary-400 transition-colors">Releases</a>
          </li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-white font-semibold mb-4">Resources</h3>
        <ul class="space-y-2">
          <li>
            <a href="/docs/getting-started/introduction" class="text-sm hover:text-primary-400 transition-colors">Getting Started</a>
          </li>
          <li>
            <a href="/docs/getting-started/installation" class="text-sm hover:text-primary-400 transition-colors">Installation</a>
          </li>
          <li>
            <a href="/docs/integrations/note-taking/notion" class="text-sm hover:text-primary-400 transition-colors">Notion Guide</a>
          </li>
          <li>
            <a href="https://github.com/shiquda/chat2note/issues" class="text-sm hover:text-primary-400 transition-colors">Support</a>
          </li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h3 class="text-white font-semibold mb-4">Community</h3>
        <ul class="space-y-2">
          <li>
            <a href="https://github.com/shiquda/chat2note" class="text-sm hover:text-primary-400 transition-colors flex items-center">
              <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>
          </li>
          <li>
            <a href="https://github.com/shiquda/chat2note/discussions" class="text-sm hover:text-primary-400 transition-colors">Discussions</a>
          </li>
          <li>
            <a href="https://github.com/shiquda/chat2note" class="text-sm hover:text-primary-400 transition-colors">Contributing</a>
          </li>
          <li>
            <a href="https://github.com/shiquda/chat2note/blob/main/LICENSE" class="text-sm hover:text-primary-400 transition-colors">License</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-sm text-gray-400">
        © {currentYear} Chat2Note. Released as open source.
      </p>
      <div class="flex space-x-6 mt-4 md:mt-0">
        <a href="/privacy" class="text-sm text-gray-400 hover:text-primary-400 transition-colors">
          Privacy Policy
        </a>
        <a href="/terms" class="text-sm text-gray-400 hover:text-primary-400 transition-colors">
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
