---
---

<section class="pt-32 pb-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-white via-primary-50/30 to-white dark:from-gray-950 dark:via-primary-950/20 dark:to-gray-950">
  <div class="container mx-auto">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 text-sm font-medium mb-6">
        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
        </svg>
        Privacy-First • No Data Tracking • 100% Local Processing
      </div>

      <!-- Main Headline -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight mb-6 leading-tight">
        <span class="block text-gray-900 dark:text-white mb-3">Collect Your</span>
        <span class="block bg-gradient-to-r from-primary-600 via-primary-500 to-blue-500 bg-clip-text text-transparent mb-3">
          AI Conversations
        </span>
        <span class="block text-gray-900 dark:text-white">Effortlessly</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-xl sm:text-2xl text-gray-600 dark:text-gray-300 mb-10 max-w-3xl mx-auto leading-relaxed">
        Save your ChatGPT, Claude, DeepSeek, Gemini, Kimi, Yuanbao, Doubao, and Grok chats to Markdown, Notion, Obsidian, or local files.
        <strong class="text-primary-600 dark:text-primary-400">Complete privacy</strong> with local processing.
      </p>

      <!-- SEO Keywords Section -->
      <div class="sr-only">
        <p>Keywords: ChatGPT export tool, Claude conversation backup, AI chat downloader, browser extension for AI conversations, Notion AI integration, Obsidian AI notes, Markdown export, privacy-focused AI tools, conversation management, AI productivity tools, note-taking app integration, knowledge management system, Notion database export, Obsidian vault integration, second brain tool, personal knowledge base PKM, research notes organizer, meeting minutes AI, chat to notes converter, conversation logging software</p>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <a
          href="/docs/getting-started/quick-start"
          class="group px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-bold rounded-xl shadow-2xl shadow-primary-500/40 transition-all hover:shadow-primary-500/60 hover:-translate-y-1 text-lg"
        >
          <span class="flex items-center">
            Read Quick Start
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </span>
        </a>
        <a
          href="https://github.com/shiquda/chat2note/releases"
          class="px-8 py-4 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-900 dark:text-white font-bold rounded-xl border-2 border-gray-200 dark:border-gray-700 shadow-lg transition-all hover:shadow-xl hover:-translate-y-1 text-lg"
        >
          Download Releases
        </a>
      </div>

      <!-- Trust Indicators -->
      <div class="flex flex-wrap items-center justify-center gap-8 text-sm text-gray-600 dark:text-gray-400">
        <div class="flex items-center">
          <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          <span class="font-medium">Privacy First</span>
        </div>
        <div class="flex items-center">
          <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          <span class="font-medium">Trusted by Professionals</span>
        </div>
        <div class="flex items-center">
          <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M13 7H7v6h6V7z"></path>
            <path fill-rule="evenodd" d="M7 2a1 1 0 012 0v1h2V2a1 1 0 112 0v1h2a2 2 0 012 2v2h1a1 1 0 110 2h-1v2h1a1 1 0 110 2h-1v2a2 2 0 01-2 2h-2v1a1 1 0 11-2 0v-1H9v1a1 1 0 11-2 0v-1H5a2 2 0 01-2-2v-2H2a1 1 0 110-2h1V9H2a1 1 0 010-2h1V5a2 2 0 012-2h2V2zM5 5h10v10H5V5z" clip-rule="evenodd"></path>
          </svg>
          <span class="font-medium">Advanced Features</span>
        </div>
      </div>
    </div>

    <!-- Screenshot/Demo Preview (Placeholder) -->
    <div class="mt-16 max-w-6xl mx-auto">
      <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-gray-200 dark:border-gray-700">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary-500/20 to-blue-500/20"></div>
        <div class="relative bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm p-8 min-h-[400px] flex items-center justify-center">
          <div class="text-center">
            <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-gradient-to-br from-primary-400 to-blue-500 flex items-center justify-center">
              <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
              </svg>
            </div>
            <p class="text-lg text-gray-600 dark:text-gray-400 font-medium">
              Product Screenshot Coming Soon
            </p>
            <p class="text-sm text-gray-500 dark:text-gray-500 mt-2">
              Export interface preview will be displayed here
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
