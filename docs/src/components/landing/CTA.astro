---
---

<section id="download" class="py-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-primary-600 via-primary-500 to-blue-600 relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>

  <div class="container mx-auto max-w-5xl relative z-10">
    <div class="text-center">
      <h2 class="text-4xl sm:text-5xl font-extrabold text-white mb-6">
        Ready to Self-Host Your Export Workflow?
      </h2>
      <p class="text-xl text-primary-100 mb-10 max-w-2xl mx-auto">
        Read the docs, install the extension, and follow releases from the public repository.
      </p>

      <!-- Download Options -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-8">
        <a
          href="https://github.com/shiquda/chat2note/releases"
          class="group w-full sm:w-auto px-8 py-4 bg-white text-primary-700 font-bold rounded-xl shadow-2xl flex items-center justify-center hover:-translate-y-1 transition-all"
        >
          <svg class="w-6 h-6 mr-3" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zm6.5 8.5L12 18 5.5 8.5h3.8L12 4l2.7 4.5z"/>
          </svg>
          <div class="text-left">
            <div class="text-xs text-primary-500 font-normal">Get builds from</div>
            <div class="text-lg">GitHub Releases</div>
          </div>
        </a>

        <a
          href="/docs/getting-started/installation"
          class="group w-full sm:w-auto px-8 py-4 bg-white/15 text-white font-bold rounded-xl shadow-2xl border border-white/30 flex items-center justify-center hover:bg-white/20 hover:-translate-y-1 transition-all"
        >
          <svg class="w-6 h-6 mr-3" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm7.5 15.8c-.1.2-.3.3-.5.2-1.2-.4-2.4-.6-3.6-.6-1.6 0-3.2.4-4.6 1.2-1.4.8-2.6 1.9-3.5 3.3-.1.2-.3.3-.5.2-.2-.1-.3-.3-.2-.5.9-1.5 2.3-2.7 3.8-3.6 1.6-.9 3.3-1.3 5.1-1.3 1.3 0 2.6.2 3.8.7.2.1.3.3.2.5z"/>
          </svg>
          <div class="text-left">
            <div class="text-xs text-white/70 font-normal">Follow the</div>
            <div class="text-lg">Installation Guide</div>
          </div>
        </a>
      </div>

      <p class="text-white/90 text-lg mb-12 font-medium">
        OSS builds for Chromium and Firefox are published from Git tags.
      </p>

      <!-- Trust Badges -->
      <div class="flex flex-wrap items-center justify-center gap-8 text-white/80">
        <div class="flex items-center">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          <span class="font-medium">Trusted by Users</span>
        </div>
        <div class="flex items-center">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path>
            <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path>
          </svg>
          <span class="font-medium">Privacy First</span>
        </div>
        <div class="flex items-center">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          <span class="font-medium">Easy to Use</span>
        </div>
      </div>

    </div>
  </div>
</section>
